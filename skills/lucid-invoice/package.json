{
  "name": "@raijinlabs/invoice",
  "version": "1.0.0",
  "description": "Lucid Invoice — Smart Billing & Revenue MCP for startups and freelancers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "invoice-mcp": "dist/bin.js"
  },
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./mcp": { "import": "./dist/mcp.js", "types": "./dist/mcp.d.ts" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "invoice",
    "billing",
    "payment",
    "subscription",
    "revenue",
    "accounting",
    "mcp",
    "lucid"
  ],
  "author": "RaijinLabs",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.5.3",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": { "node": ">=18.0.0" }
}
