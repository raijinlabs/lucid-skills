{
  "id": "lucid-veille",
  "name": "Lucid Veille",
  "version": "1.0.0",
  "description": "Content monitoring, AI digest generation, and auto-publishing — OpenClaw plugin + MCP server",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "supabaseUrl": { "type": "string" },
      "supabaseKey": { "type": "string" },
      "tenantId": { "type": "string", "default": "personal" },
      "timezone": { "type": "string", "default": "Europe/Paris" },
      "language": { "type": "string", "default": "fr" },
      "fetchCron": { "type": "string", "default": "0 6 * * *" },
      "dailyDigestCron": { "type": "string", "default": "0 8 * * *" },
      "weeklyDigestCron": { "type": "string", "default": "0 9 * * 1" },
      "autoPublish": { "type": "boolean", "default": false },
      "digestTrustThreshold": { "type": "number", "default": 30 },
      "digestMaxItems": { "type": "number", "default": 50 },
      "twitterBearerToken": { "type": "string" },
      "twitterApiKey": { "type": "string" },
      "twitterApiSecret": { "type": "string" },
      "twitterAccessToken": { "type": "string" },
      "twitterAccessSecret": { "type": "string" },
      "ghostUrl": { "type": "string" },
      "ghostAdminApiKey": { "type": "string" },
      "wordpressUrl": { "type": "string" },
      "wordpressUsername": { "type": "string" },
      "wordpressPassword": { "type": "string" },
      "linkedinAccessToken": { "type": "string" },
      "devtoApiKey": { "type": "string" },
      "telegramBotToken": { "type": "string" },
      "telegramChatId": { "type": "string" },
      "slackWebhookUrl": { "type": "string" },
      "discordWebhookUrl": { "type": "string" }
    }
  },
  "uiHints": {
    "supabaseUrl": { "label": "Supabase URL", "placeholder": "https://xxx.supabase.co" },
    "supabaseKey": { "label": "Supabase Service Role Key", "sensitive": true },
    "tenantId": { "label": "Tenant ID", "placeholder": "personal" },
    "timezone": { "label": "Timezone", "placeholder": "Europe/Paris" },
    "language": { "label": "Digest Language", "placeholder": "fr" },
    "fetchCron": { "label": "Fetch Schedule (cron)", "placeholder": "0 6 * * *" },
    "dailyDigestCron": { "label": "Daily Digest Schedule", "placeholder": "0 8 * * *" },
    "weeklyDigestCron": { "label": "Weekly Digest Schedule", "placeholder": "0 9 * * 1" },
    "autoPublish": { "label": "Auto-publish digests" },
    "twitterBearerToken": { "label": "Twitter Bearer Token", "sensitive": true },
    "twitterApiKey": { "label": "Twitter API Key", "sensitive": true },
    "twitterApiSecret": { "label": "Twitter API Secret", "sensitive": true },
    "twitterAccessToken": { "label": "Twitter Access Token", "sensitive": true },
    "twitterAccessSecret": { "label": "Twitter Access Secret", "sensitive": true },
    "ghostUrl": { "label": "Ghost URL", "placeholder": "https://your-blog.ghost.io" },
    "ghostAdminApiKey": { "label": "Ghost Admin API Key", "sensitive": true },
    "wordpressUrl": { "label": "WordPress URL" },
    "wordpressUsername": { "label": "WordPress Username" },
    "wordpressPassword": { "label": "WordPress Password", "sensitive": true },
    "linkedinAccessToken": { "label": "LinkedIn Access Token", "sensitive": true },
    "devtoApiKey": { "label": "dev.to API Key", "sensitive": true },
    "telegramBotToken": { "label": "Telegram Bot Token", "sensitive": true },
    "telegramChatId": { "label": "Telegram Chat ID" },
    "slackWebhookUrl": { "label": "Slack Webhook URL", "sensitive": true },
    "discordWebhookUrl": { "label": "Discord Webhook URL", "sensitive": true }
  }
}
