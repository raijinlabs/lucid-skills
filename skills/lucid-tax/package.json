{
  "name": "@raijinlabs/tax",
  "version": "2.0.0",
  "description": "Lucid Tax — Crypto Tax & DeFi Accounting MCP: AI brain layer with verdicts, cost-basis optimization, tax-loss harvesting, multi-jurisdiction support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tax-mcp": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src/ test/",
    "format": "prettier --write src/ test/"
  },
  "keywords": [
    "crypto",
    "tax",
    "defi",
    "accounting",
    "cost-basis",
    "capital-gains",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Raijin Labs",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "bottleneck": "^2.19.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
