{
  "name": "@raijinlabs/hype",
  "version": "0.1.0",
  "description": "Lucid Hype — growth hacking & social promotion MCP with personality engines, viral content generation, engagement optimization, community infiltration, and influencer identification",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hype-mcp": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./openclaw": {
      "types": "./dist/openclaw.d.ts",
      "import": "./dist/openclaw.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check src/ test/",
    "format": "prettier --write src/ test/"
  },
  "keywords": [
    "growth",
    "marketing",
    "social",
    "promotion",
    "viral",
    "engagement",
    "influencer",
    "community",
    "mcp",
    "lucid"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
